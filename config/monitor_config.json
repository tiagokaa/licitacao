{
  "keywords": [
    "cal virgem",
    "cal hidratada",
    "calcario",
    "calcario agricola",
    "calcario calcitico",
    "calcario dolomitico",
    "corretivo de solo"
  ],
  "window_days": 14,
  "destinations": {
    "emails": [
      "compras@empresa.com"
    ]
  },
  "output": {
    "daily_dir": "data/daily",
    "template_csv": "data/modelo_licitacoes.csv",
    "historical_csv": "data/consolidado_historico.csv",
    "state_file": "data/estado_chaves_dedup.txt"
  },
  "sources": {
    "pncp": {
      "enabled": true,
      "base_url": "https://pncp.gov.br/api/consulta/v1/contratacoes/publicacao",
      "page_size": 10,
      "max_pages": 3,
      "codigo_modalidade_contratacao": [
        10
      ],
      "only_open": true,
      "query_chunk_days": 3,
      "request_retries": 2,
      "max_consecutive_failures": 2,
      "fail_on_unavailable": false,
      "timeout_seconds": 20
    },
    "compras_gov_br": {
      "enabled": false
    },
    "licitacoes_e": {
      "enabled": false
    },
    "bec_sp": {
      "enabled": false
    },
    "portais_estaduais_municipais": {
      "enabled": false
    }
  }
}
